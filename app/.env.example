# ============================================================
# Steadfast Student Services — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# --- Supabase (https://supabase.com) ---
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google Gemini AI (https://aistudio.google.com) ---
# Free tier: 1M tokens/day — no cost at launch
GEMINI_API_KEY=your-gemini-api-key

# --- Resend Email (https://resend.com) ---
# Free tier: 3,000 emails/month
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=advisors@steadfaststudentservices.com

# --- Cal.com Booking ---
CAL_API_KEY=your-cal-api-key
CAL_EVENT_TYPE_ID=your-consultation-event-type-id

# --- Stripe Payments (https://stripe.com) ---
# No monthly fee — only pay when you earn
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://www.steadfaststudentservices.com
NEXT_PUBLIC_COMPANY_NAME=Steadfast Student Services

# --- Google Analytics 4 ---
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX   # Your GA4 Measurement ID

# --- Admin ---
ADMIN_EMAIL=admin@steadfaststudentservices.com
# Password required to view /admin (HTTP Basic Auth, checked in middleware.ts).
# Without this set, /admin is blocked entirely rather than left open.
ADMIN_PASSWORD=choose-a-strong-password

# --- Twilio WhatsApp Bot (https://twilio.com) ---
# Free trial: $15 credit. Production WhatsApp number: ~$5/month
# 1. Create a Twilio account
# 2. Go to Messaging > Try it out > Send a WhatsApp message (sandbox for testing)
# 3. For production: apply for a WhatsApp Business number in Twilio console
# 4. Set webhook URL in Twilio to: https://www.steadfaststudentservices.com/api/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886   # Your Twilio WhatsApp number (sandbox: +14155238886)
ADVISOR_WHATSAPP_NUMBER=+1XXXXXXXXXX  # YOUR personal WhatsApp number for lead alerts
